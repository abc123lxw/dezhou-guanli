PORT=3001
DATABASE_PATH=./data/bar.db

# 微信小程序（上线必填）
WECHAT_APPID=
WECHAT_SECRET=

# 微信支付（上线必填）
WECHAT_MCH_ID=
WECHAT_MCH_KEY=
WECHAT_PAY_NOTIFY_URL=https://你的域名/api/pay/notify

# 订阅消息：订单制作完成（微信公众平台申请模板后填入）
WX_SUBSCRIBE_TEMPLATE_ORDER_DONE=

# 消费 1 元得多少积分
POINTS_PER_YUAN=1

# 开发模式：true 时无微信密钥则 mock 登录；false 为生产
DEV_MODE=true

# 吧台管理员初始密码（仅 seed 时使用）
ADMIN_PASSWORD=dybar2026

# 数据库自动备份
BACKUP_INTERVAL_HOURS=24
BACKUP_KEEP_DAYS=14
